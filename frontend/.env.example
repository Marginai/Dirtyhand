# Leave empty in dev to use Vite proxy (/api -> backend)
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: proxy target for `npm run dev` (see vite.config.ts)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional: when backend requires API_SERVICE_KEY, set this in frontend deploy env
# and requests will include: Authorization: Bearer <token>
# VITE_API_BEARER_TOKEN=your-api-service-key
