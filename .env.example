# Required
OPENAI_API_KEY=sk-your-key-here

# App
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# CORS — comma-separated (required in production for your real UI origin)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: require Authorization: Bearer <token> for POST /api/v1/chat and /api/v1/ingest
# API_SERVICE_KEY=

# Rate limit (per IP, per minute)
RATE_LIMIT_PER_MINUTE=60
# Stricter limit for chat (abuse prevention)
RATE_LIMIT_CHAT_PER_MINUTE=20

# Max request body sizes (defense-in-depth against memory/CPU DoS)
# Content-Length must be present for enforcement (typical for JSON and uploads).
MAX_REQUEST_BYTES_CHAT=8000000
MAX_REQUEST_BYTES_INGEST=8000000
MAX_REQUEST_BYTES_SCRAPE_INGEST=5000000
MAX_REQUEST_BYTES_INGEST_DB=50000000

# Models
LLM_MODEL=gpt-5.4
EMBEDDING_MODEL=text-embedding-3-large

# RAG storage (default: backend/data/chroma under project root)
# CHROMA_PERSIST_DIR=backend/data/chroma
RAG_COLLECTION_NAME=rag_docs_gpt54_emb3l

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_ACTION_TIMEOUT_MS=10000
# Comma-separated domain allowlist for Playwright navigation.
# Example: PLAYWRIGHT_ALLOWED_DOMAINS=example.com,sub.example.com
# If empty, no allowlist enforcement is applied unless you set
# PLAYWRIGHT_ENFORCE_DOMAIN_ALLOWLIST=true.
PLAYWRIGHT_ALLOWED_DOMAINS=
# If true, block navigation to hosts not in PLAYWRIGHT_ALLOWED_DOMAINS.
PLAYWRIGHT_ENFORCE_DOMAIN_ALLOWLIST=false
# Always block navigation to localhost/private IPs (recommended).
PLAYWRIGHT_BLOCK_PRIVATE_IPS=true
# In production, strongly recommended:
# PLAYWRIGHT_ENFORCE_DOMAIN_ALLOWLIST=true
# PLAYWRIGHT_ALLOWED_DOMAINS=yourdomain.com,docs.yourdomain.com

# Agent
RAG_RETRIEVAL_K=4
AGENT_RECURSION_LIMIT=25

# Default site URL for Playwright scraping tools / scrape-ingest.
# If set, you can omit `url` from requests and tools will use this.
# ORGANIZATION_URL=https://marginai.co.uk
ORGANIZATION_URL=

# Docs in production (default off)
SHOW_OPENAPI=false

# Langfuse (optional) — traces + pass_rate scores
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
